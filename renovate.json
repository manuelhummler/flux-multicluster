{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "branchConcurrentLimit": 20,
  "flux": {
    "managerFilePatterns": [
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/infrastructure/.+\\.yaml$/"
    ]
  },
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "ghcr.io",
      "username": "blackwolfk-9",
      "password": "{{ secrets.GHCR_TOKEN }}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/juno-care/vibecode-mvp-v1"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchPackageNames": ["ghcr.io/open-project-e-v/fest-der-demokratie"],
      "versioning": "numeric",
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true,
      "prPriority": 10
    }
  ]
}
