{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "flux": {
    "fileMatch": ["infrastructure/.+\\.yaml$"]
  },
  "kubernetes": {
    "fileMatch": ["infrastructure/.+\\.yaml$"]
  },
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "ghcr.io",
      "username": "blackwolfk-9",
      "password": "{{ secrets.GHCR_TOKEN }}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/juno-care/vibecode-mvp-v1"],
      "automerge": true,
      "automergeType": "branch"
    }
  ]
}
